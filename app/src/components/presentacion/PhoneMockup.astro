---
/**
 * PhoneMockup.astro — Marco de móvil Android estilizado
 *
 * Muestra el contenido del slot dentro de un frame de smartphone.
 * Si no hay contenido real, muestra un placeholder con icono.
 *
 * Props:
 *   featured     {boolean}  Si true, el frame es más grande (slide central).
 *   label        {string}   Texto descriptivo debajo del mockup. Opcional.
 *   placeholder  {string}   Emoji/icono para el placeholder si no hay slot. Default: 📱
 *   animDelay    {number}   Retraso de animación 1-6. Opcional.
 */
interface Props {
  featured?: boolean;
  label?: string;
  placeholder?: string;
  animDelay?: 1 | 2 | 3 | 4 | 5 | 6;
}

const {
  featured = false,
  label,
  placeholder = '📱',
  animDelay,
} = Astro.props;

const wrapperClass = [
  'phone-mockup',
  featured ? 'featured' : '',
  animDelay ? `animate-scale delay-${animDelay}` : 'animate-scale',
].filter(Boolean).join(' ');

// Comprueba si se pasó contenido real al slot
const hasContent = Astro.slots.has('default');
---

<div class={wrapperClass}>
  <!-- Marco del teléfono -->
  <div class="phone-frame" aria-label={label ?? 'Pantalla de la aplicación'}>
    <div class="phone-screen">
      {hasContent
        ? <slot />  <!-- Imagen real o contenido personalizado -->
        : (
            <!-- Placeholder visual cuando no hay captura real -->
            <div class="placeholder-screen" aria-hidden="true">
              {placeholder}
            </div>
          )
      }
    </div>
  </div>

  <!-- Etiqueta debajo del mockup -->
  {label && (
    <p class="phone-label">{label}</p>
  )}
</div>

<style>
  .phone-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text-muted);
    text-align: center;
    margin-top: 10px;
    line-height: 1.3;
  }
</style>
