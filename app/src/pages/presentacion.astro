    <nav class="slide-controls" aria-label="Controles de presentacion">
      <span class="keyboard-hint" aria-hidden="true">← → para navegar · F para pantalla completa</span>
      <span class="slide-counter" id="slideCounter" aria-live="polite">1 / 14</span>
      <span class="slide-current-title" id="slideTitle" aria-hidden="true">Portada</span>

      <div class="controls-center">
        <button class="btn-nav" id="btnPrev" aria-label="Diapositiva anterior" disabled>&larr;</button>
        <div class="dots-track" id="dotsTrack" role="tablist" aria-label="Diapositivas"></div>
        <button class="btn-nav" id="btnNext" aria-label="Diapositiva siguiente">&rarr;</button>
      </div>

      <button class="btn-fullscreen" id="btnFullscreen" aria-label="Activar pantalla completa">
        <svg id="iconExpand" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>
        </svg>
        <svg id="iconCompress" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
          <path d="M8 3v3a2 2 0 0 1-2 2H3m18 0h-3a2 2 0 0 1-2-2V3m0 18v-3a2 2 0 0 1 2-2h3M3 16h3a2 2 0 0 1 2 2v3"/>
        </svg>
        <span>Pantalla completa</span>
      </button>
    </nav>
  </div>
</PresentacionLayout>

<script>
  (() => {
    const TOTAL = 14;
    const SLIDE_TITLES = ["Portada","Indice","El Problema","Investigacion de Usuarios","Interes del Mercado","Persona Prototipo","Propuesta de Valor","MVP y Requisitos","Arquitectura","Motor de Decision","Prototipo Funcional","Flujo de Uso y Privacidad","Viabilidad y Costes","Conclusion"];

    let current = 1;
    let isAnimating = false;

    const counter = document.getElementById('slideCounter');
    const titleLabel = document.getElementById('slideTitle');
    const progressFill = document.getElementById('progressFill');
    const btnPrev = document.getElementById('btnPrev');
    const btnNext = document.getElementById('btnNext');
    const btnFS = document.getElementById('btnFullscreen');
    const dotsTrack = document.getElementById('dotsTrack');
    const iconExpand = document.getElementById('iconExpand');
    const iconCompress = document.getElementById('iconCompress');

    function getSlide(n) {
      return document.getElementById(`slide-${n}`);
    }

    function buildDots() {
      for (let i = 1; i <= TOTAL; i += 1) {
        const dot = document.createElement('button');
        dot.className = i === 1 ? 'dot active' : 'dot';
        dot.type = 'button';
        dot.setAttribute('role', 'tab');
        dot.setAttribute('aria-label', `Diapositiva ${i}: ${SLIDE_TITLES[i - 1]}`);
        dot.setAttribute('aria-selected', i === 1 ? 'true' : 'false');
        dot.dataset.goto = String(i);
        dotsTrack.appendChild(dot);
      }
    }

    function replayAnimations(slide) {
      slide.querySelectorAll('[class*="animate-"]').forEach((el) => {
        el.style.animation = 'none';
        void el.offsetHeight;
        el.style.animation = '';
      });
    }

    function goTo(target, direction = 'forward') {
      if (target < 1 || target > TOTAL || target === current || isAnimating) return;
      isAnimating = true;

      const prevSlide = getSlide(current);
      const nextSlide = getSlide(target);

      nextSlide.style.transition = 'none';
      nextSlide.classList.remove('enter-from-left');
      nextSlide.style.opacity = '0';
      const mobile = window.matchMedia('(max-width: 900px)').matches;
      nextSlide.style.transform = direction === 'forward'
        ? (mobile ? 'translateX(40px)' : 'translate(calc(-50% + 60px), -50%)')
        : (mobile ? 'translateX(-40px)' : 'translate(calc(-50% - 60px), -50%)');

      void nextSlide.offsetHeight;

      nextSlide.style.transition = '';
      replayAnimations(nextSlide);

      prevSlide.classList.remove('active');
      prevSlide.classList.add(direction === 'forward' ? 'exit-left' : 'exit-right');

      nextSlide.classList.add('active');
      nextSlide.style.opacity = '';
      nextSlide.style.transform = '';

      window.setTimeout(() => {
        prevSlide.classList.remove('exit-left', 'exit-right');
        nextSlide.style.transition = '';
        isAnimating = false;
      }, 420);

      current = target;
      updateUI();
    }

    function updateUI() {
      counter.textContent = `${current} / ${TOTAL}`;
      const slideTitle = SLIDE_TITLES[current - 1];
      titleLabel.textContent = slideTitle;
      document.title = `${slideTitle} - Presentacion TFC`;
      progressFill.style.width = `${(current / TOTAL) * 100}%`;
      btnPrev.disabled = current === 1;
      btnNext.disabled = current === TOTAL;

      dotsTrack.querySelectorAll('.dot').forEach((dot, index) => {
        const active = index + 1 === current;
        dot.classList.toggle('active', active);
        dot.setAttribute('aria-selected', active ? 'true' : 'false');
      });
    }

    function updateFSIcon() {
      const isFS = Boolean(document.fullscreenElement);
      iconExpand.style.display = isFS ? 'none' : '';
      iconCompress.style.display = isFS ? '' : 'none';
      btnFS.querySelector('span').textContent = isFS ? 'Salir pantalla completa' : 'Pantalla completa';
    }

    function toggleFullscreen() {
      if (!document.fullscreenElement) {
        document.documentElement.requestFullscreen?.().catch(() => {});
      } else {
        document.exitFullscreen?.();
      }
    }

    buildDots();
    updateUI();

    btnPrev.addEventListener('click', () => goTo(current - 1, 'backward'));
    btnNext.addEventListener('click', () => goTo(current + 1, 'forward'));
    btnFS.addEventListener('click', toggleFullscreen);

    dotsTrack.addEventListener('click', (event) => {
      const dot = event.target.closest('.dot');
      if (!dot) return;
      const target = Number.parseInt(dot.dataset.goto, 10);
      goTo(target, target > current ? 'forward' : 'backward');
    });

    document.querySelectorAll('[data-goto]').forEach((element) => {
      if (element.classList.contains('dot')) return;
      element.addEventListener('click', () => {
        const target = Number.parseInt(element.dataset.goto, 10);
        goTo(target, target > current ? 'forward' : 'backward');
      });
    });

    document.addEventListener('keydown', (event) => {
      if (['INPUT', 'TEXTAREA', 'SELECT'].includes(document.activeElement?.tagName)) return;

      switch (event.key) {
        case 'ArrowRight':
        case 'ArrowDown':
        case ' ':
          event.preventDefault();
          goTo(current + 1, 'forward');
          break;
        case 'ArrowLeft':
        case 'ArrowUp':
          event.preventDefault();
          goTo(current - 1, 'backward');
          break;
        case 'Home':
          event.preventDefault();
          goTo(1, 'backward');
          break;
        case 'End':
          event.preventDefault();
          goTo(TOTAL, 'forward');
          break;
        case 'f':
        case 'F':
          toggleFullscreen();
          break;
        default:
          break;
      }
    });

    document.addEventListener('fullscreenchange', updateFSIcon);
    document.addEventListener('webkitfullscreenchange', updateFSIcon);
  })();
</script>
