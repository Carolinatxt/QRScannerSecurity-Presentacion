<!-- =====================================================
     JAVASCRIPT DE NAVEGACIÓN — FASE 2
     Transiciones bidireccionales, dots, swipe táctil,
     fullscreen dinámico, hint de teclado.
     ===================================================== -->
<script>
  (() => {
    // ─────────────────────────────────────────────────
    // DATOS
    // ─────────────────────────────────────────────────
    const TOTAL = 14;
    const SLIDE_TITLES = [
      'Portada', 'Índice', 'El Problema', 'Investigación de Usuarios',
      'Interés del Mercado', 'Persona Prototipo', 'Propuesta de Valor',
      'MVP y Requisitos', 'Arquitectura', 'Motor de Decisión',
      'Prototipo Funcional', 'Flujo de Uso y Privacidad', 'Viabilidad y Costes', 'Conclusión',
    ];

    let current = 1;
    let isAnimating = false; // evita clics rápidos que rompan la animación

    // ─────────────────────────────────────────────────
    // SELECTORES
    // ─────────────────────────────────────────────────
    const counter      = document.getElementById('slideCounter');
    const titleLabel   = document.getElementById('slideTitle');
    const progressFill = document.getElementById('progressFill');
    const btnPrev      = document.getElementById('btnPrev');
    const btnNext      = document.getElementById('btnNext');
    const btnFS        = document.getElementById('btnFullscreen');
    const dotsTrack    = document.getElementById('dotsTrack');
    const iconExpand   = document.getElementById('iconExpand');
    const iconCompress = document.getElementById('iconCompress');

    // ─────────────────────────────────────────────────
    // DOTS — generación dinámica
    // ─────────────────────────────────────────────────
    function buildDots() {
      for (let i = 1; i <= TOTAL; i++) {
        const dot = document.createElement('button');
        dot.className = 'dot' + (i === 1 ? ' active' : '');
        dot.setAttribute('role', 'tab');
        dot.setAttribute('aria-label', `Diapositiva ${i}: ${SLIDE_TITLES[i - 1]}`);
        dot.setAttribute('aria-selected', i === 1 ? 'true' : 'false');
        dot.dataset.goto = String(i);
        dotsTrack.appendChild(dot);
      }
    }
    buildDots();

    // ─────────────────────────────────────────────────
    // HELPER: obtiene el elemento .slide por número
    // ─────────────────────────────────────────────────
    function getSlide(n) {
      return document.getElementById(`slide-${n}`);
    }

    // ─────────────────────────────────────────────────
    // NAVEGACIÓN PRINCIPAL
    // ─────────────────────────────────────────────────
    /**
     * Navega a una diapositiva con transición bidireccional.
     * @param {number} target     Número destino (1-based)
     * @param {string} direction  'forward' | 'backward'
     */
    function goTo(target, direction = 'forward') {
      if (target < 1 || target > TOTAL || target === current || isAnimating) return;
      isAnimating = true;

      const prevSlide = getSlide(current);
      const nextSlide = getSlide(target);

      // 1. Prepara la slide entrante en la posición correcta (sin transición)
      nextSlide.style.transition = 'none';
      if (direction === 'forward') {
        nextSlide.classList.remove('enter-from-left');
        nextSlide.style.transform = 'translateX(60px)';
      } else {
        nextSlide.classList.add('enter-from-left');
        nextSlide.style.transform = 'translateX(-60px)';
      }
      nextSlide.style.opacity = '0';

      // 2. Fuerza reflow para que el navegador aplique el estado inicial
      void nextSlide.offsetHeight;

      // 3. Reactiva la transición CSS
      nextSlide.style.transition = '';

      // 4. Re-dispara las animaciones CSS internas (fade-up, scale, etc.)
      nextSlide.querySelectorAll('[class*="animate-"]').forEach(el => {
        el.style.animation = 'none';
        void el.offsetHeight; // reflow
        el.style.animation = '';
      });

      // 5. Aplica clases de salida a la slide actual
      prevSlide.classList.remove('active');
      prevSlide.classList.add(direction === 'forward' ? 'exit-left' : 'exit-right');

      // 6. Activa la slide entrante
      nextSlide.classList.add('active');
      nextSlide.classList.remove('enter-from-left');
      nextSlide.style.transform = '';
      nextSlide.style.opacity = '';

      // 7. Limpieza tras la transición
      const DURATION = 380; // Sincronizado con --transition-duration (0.35s + buffer)
      setTimeout(() => {
        prevSlide.classList.remove('exit-left', 'exit-right');
        isAnimating = false;
      }, DURATION);

      current = target;
      updateUI();
    }

    // ─────────────────────────────────────────────────
    // UPDATE UI — contador, progreso, dots, título
    // ─────────────────────────────────────────────────
    function updateUI() {
      // Contador
      counter.textContent = `${current} / ${TOTAL}`;

      // Título de la slide en la barra y en el documento (A11y)
      const slideTitle = SLIDE_TITLES[current - 1];
      titleLabel.textContent = slideTitle;
      document.title = `${slideTitle} — Presentación TFC`;

      // Barra de progreso
      progressFill.style.width = `${(current / TOTAL) * 100}%`;

      // Botones anterior / siguiente
      btnPrev.disabled = current === 1;
      btnNext.disabled = current === TOTAL;

      // Dots activos
      dotsTrack.querySelectorAll('.dot').forEach((dot, i) => {
        const isActive = i + 1 === current;
        dot.classList.toggle('active', isActive);
        dot.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });

      triggerSlideAnimations(current);
    }

    // ─────────────────────────────────────────────────
    // ANIMACIONES ESPECÍFICAS DE SLIDES
    // ─────────────────────────────────────────────────
    function triggerSlideAnimations(slideNum) {
      // SLIDE 9: Arquitectura
      if (slideNum === 9) {
        const archSlide = getSlide(9);
        const nodes = archSlide.querySelectorAll('.arch-anim');
        
        // Reset
        nodes.forEach(n => n.classList.remove('visible'));

        // Delay escalonado
        nodes.forEach((node) => {
          const idx = parseInt(node.dataset.archIndex || '0', 10);
          setTimeout(() => {
            node.classList.add('visible');
          }, 300 + (idx * 300));
        });
      }
    }

    // ─────────────────────────────────────────────────
    // EVENTOS DE BOTONES
    // ─────────────────────────────────────────────────
    btnPrev.addEventListener('click', () => goTo(current - 1, 'backward'));
    btnNext.addEventListener('click', () => goTo(current + 1, 'forward'));

    // Dots individuales
    dotsTrack.addEventListener('click', (e) => {
      const dot = e.target.closest('.dot');
      if (!dot) return;
      const target = parseInt(dot.dataset.goto, 10);
      goTo(target, target > current ? 'forward' : 'backward');
    });

    // Índice interactivo (data-goto en cualquier elemento)
    document.querySelectorAll('[data-goto]').forEach(btn => {
      // Los dots ya están manejados arriba; evitar duplicados
      if (btn.classList.contains('dot')) return;
      btn.addEventListener('click', () => {
        const target = parseInt(btn.dataset.goto, 10);
        goTo(target, target > current ? 'forward' : 'backward');
      });
    });

    // ─────────────────────────────────────────────────
    // TECLADO
    // ─────────────────────────────────────────────────
    document.addEventListener('keydown', (e) => {
      // No actuar si el foco está en un input/textarea
      if (['INPUT','TEXTAREA','SELECT'].includes(document.activeElement?.tagName)) return;

      switch (e.key) {
        case 'ArrowRight':
        case ' ':           e.preventDefault(); goTo(current + 1, 'forward');  break;
        case 'ArrowLeft':   e.preventDefault(); goTo(current - 1, 'backward'); break;
        case 'ArrowDown':   e.preventDefault(); goTo(current + 1, 'forward');  break;
        case 'ArrowUp':     e.preventDefault(); goTo(current - 1, 'backward'); break;
        case 'Home':        e.preventDefault(); goTo(1, 'backward');            break;
        case 'End':         e.preventDefault(); goTo(TOTAL, 'forward');         break;
        case 'f':
        case 'F':           toggleFullscreen(); break;
        case 'Escape':      /* el navegador ya sale de FS con Escape */          break;
      }
    });

    // ─────────────────────────────────────────────────
    // PANTALLA COMPLETA
    // ─────────────────────────────────────────────────
    function updateFSIcon() {
      const isFS = !!document.fullscreenElement;
      iconExpand.style.display   = isFS ? 'none'  : '';
      iconCompress.style.display = isFS ? ''      : 'none';
      btnFS.querySelector('span').textContent =
        isFS ? 'Salir pantalla completa' : 'Pantalla completa';
    }

    function toggleFullscreen() {
      if (!document.fullscreenElement) {
        document.documentElement.requestFullscreen?.().catch(() => {});
      } else {
        document.exitFullscreen?.();
      }
    }

    btnFS.addEventListener('click', toggleFullscreen);
    document.addEventListener('fullscreenchange', updateFSIcon);
    document.addEventListener('webkitfullscreenchange', updateFSIcon);

    // ─────────────────────────────────────────────────
    // SWIPE TÁCTIL
    // ─────────────────────────────────────────────────
    let touchStartX = 0;
    let touchStartY = 0;
    const SWIPE_THRESHOLD = 50; // px mínimos para considerar swipe

    document.addEventListener('touchstart', (e) => {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
    }, { passive: true });

    document.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      const dy = e.changedTouches[0].clientY - touchStartY;

      // Solo procesa si el movimiento horizontal es mayor que el vertical
      if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > SWIPE_THRESHOLD) {
        if (dx < 0) goTo(current + 1, 'forward');  // swipe izquierda = avanzar
        else        goTo(current - 1, 'backward'); // swipe derecha  = retroceder
      }
    }, { passive: true });

    // ─────────────────────────────────────────────────
    // INICIO
    // ─────────────────────────────────────────────────
    updateUI();
  })();
</script>
