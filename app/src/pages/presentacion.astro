---
import PresentacionLayout from '../layouts/PresentacionLayout.astro';
import PhoneMockup from '../components/presentacion/PhoneMockup.astro';

const TOTAL_SLIDES = 14;

const slideTitles = [
  'Portada',
  'Indice',
  'El Problema',
  'Investigacion de Usuarios',
  'Interes del Mercado',
  'Persona Prototipo',
  'Propuesta de Valor',
  'MVP y Requisitos',
  'Arquitectura',
  'Motor de Decision',
  'Prototipo Funcional',
  'Flujo de Uso y Privacidad',
  'Viabilidad y Costes',
  'Conclusion',
];

const iconCamera = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>`;
const iconLink = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07L11.5 5"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07L12.5 19"/></svg>`;
const iconShield = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 5v6c0 5 3.4 9.7 8 11 4.6-1.3 8-6 8-11V5l-8-3z"/><path d="m9 12 2 2 4-4"/></svg>`;
const iconSearch = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/></svg>`;
const iconClock = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>`;
const iconSave = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><path d="M17 21v-8H7v8"/><path d="M7 3v5h8"/></svg>`;
const iconRefresh = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M1 4v6h6"/><path d="M23 20v-6h-6"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10"/><path d="M3.51 15A9 9 0 0 0 18.36 18.36L23 14"/></svg>`;
const iconLock = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`;
const iconLayers = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m12 2 9 5-9 5-9-5 9-5Z"/><path d="m3 12 9 5 9-5"/><path d="m3 17 9 5 9-5"/></svg>`;
const iconPhone = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="7" y="2" width="10" height="20" rx="2"/><path d="M11.5 18h1"/></svg>`;
const iconServer = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="6" rx="2"/><rect x="3" y="14" width="18" height="6" rx="2"/><path d="M7 7h.01"/><path d="M7 17h.01"/></svg>`;
const iconDatabase = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="8" ry="3"/><path d="M4 5v7c0 1.7 3.6 3 8 3s8-1.3 8-3V5"/><path d="M4 12v7c0 1.7 3.6 3 8 3s8-1.3 8-3v-7"/></svg>`;
const iconResult = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><path d="M21 12a9 9 0 1 1-5.2-8.2"/></svg>`;
const iconSend = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2 11 13"/><path d="m22 2-7 20-4-9-9-4 20-7Z"/></svg>`;
const iconUser = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21a8 8 0 0 0-16 0"/><circle cx="12" cy="8" r="5"/></svg>`;
const iconAlert = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 9v4"/><path d="M12 17h.01"/><path d="M10.29 3.86 1.82 18A2 2 0 0 0 3.53 21h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"/></svg>`;
const iconStar = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m12 2 3.1 6.3 7 1-5 4.8 1.2 6.9-6.3-3.4-6.3 3.4L6.9 14.1l-5-4.8 7-1L12 2Z"/></svg>`;

const indexBlocks = [
  { num: '01', title: 'Problema', sub: 'QR y punto ciego', goto: 3, slides: 'Slide 3' },
  { num: '02', title: 'Usuario y mercado', sub: 'Datos y demanda', goto: 4, slides: 'Slides 4-6' },
  { num: '03', title: 'Solucion y MVP', sub: 'Que se entrega', goto: 7, slides: 'Slides 7-8' },
  { num: '04', title: 'Arquitectura', sub: 'Cliente, backend, fuentes', goto: 9, slides: 'Slides 9-10' },
  { num: '05', title: 'Prototipo', sub: 'Demo Android real', goto: 11, slides: 'Slides 11-12' },
  { num: '06', title: 'Viabilidad y cierre', sub: 'Costes y conclusion', goto: 13, slides: 'Slides 13-14' },
];

const researchStats = [
  { value: '37', label: 'participantes', text: 'Cuestionario validado.' },
  { value: '84%', label: 'usa QR con frecuencia', text: 'Uso cotidiano consolidado.' },
  { value: '46%', label: 'no revisa la URL', text: 'Abre sin comprobar el destino.' },
];

const marketStats = [
  { value: '68%', label: 'la usaria', text: 'Hay interes directo.' },
  { value: '30%', label: 'depende de la rapidez', text: 'La friccion penaliza.' },
  { value: '49%', label: 'prioriza simplicidad', text: 'La lectura debe ser inmediata.' },
];

const personaCards = [
  { title: 'Contexto', text: 'Restaurantes, transporte y comercios.', icon: iconUser, tone: 'neutral' },
  { title: 'Problema', text: 'No distingue un enlace legitimo de uno fraudulento.', icon: iconAlert, tone: 'danger' },
  { title: 'Necesidad', text: 'Una respuesta clara antes de abrir.', icon: iconClock, tone: 'neutral' },
  { title: 'Expectativa', text: 'Seguro, sospechoso o peligroso.', icon: iconStar, tone: 'success' },
];

const valueSteps = [
  { num: '1', title: 'Captura', text: 'QR o URL', tone: 'muted' },
  { num: '2', title: 'Analisis', text: 'Backend, reglas y fuentes', tone: 'featured' },
  { num: '3', title: 'Decision', text: 'Semaforo y accion', tone: 'muted' },
];

const mvpFeatures = [
  { title: 'Escanear QR', text: 'Lectura ZXing', icon: iconCamera },
  { title: 'Introducir URL', text: 'Entrada directa', icon: iconLink },
  { title: 'Validar enlace', text: 'Filtro local', icon: iconShield },
  { title: 'Analizar destino', text: 'Revision remota', icon: iconSearch },
  { title: 'Mostrar semaforo', text: 'Resultado claro', icon: iconClock },
  { title: 'Guardar historial', text: 'Room local', icon: iconSave },
  { title: 'Reanalizar', text: 'Nueva consulta', icon: iconRefresh },
  { title: 'Control de apertura', text: 'Apertura manual', icon: iconLock },
];

const requirements = [
  { id: 'R1-F', text: 'Camara QR', icon: iconCamera },
  { id: 'R2-F', text: 'Bloqueo autoapertura', icon: iconLock },
  { id: 'R3-F', text: 'URL manual', icon: iconLink },
  { id: 'R4-F', text: 'Revision web', icon: iconShield },
  { id: 'R5-F', text: 'Risk level', icon: iconLayers },
  { id: 'R6-F', text: 'Resumen claro', icon: iconResult },
  { id: 'R7-F', text: 'Historial local', icon: iconSave },
];

const architectureZones = [
  {
    title: 'Cliente Android',
    text: 'Captura, prevalidacion, UI e historial.',
    chips: ['ZXing', 'Compose', 'ViewModel', 'Retrofit', 'Room'],
    icon: iconPhone,
    tone: 'client',
  },
  {
    title: 'Backend FastAPI',
    text: 'Valida, orquesta y decide.',
    chips: ['FastAPI', 'Docker', 'Motor decision'],
    icon: iconServer,
    tone: 'backend',
  },
  {
    title: 'Fuentes',
    text: 'Reputacion y apoyo visual.',
    chips: ['Web Risk', 'IPQS', 'OpenPhish', 'SnapRender'],
    icon: iconDatabase,
    tone: 'sources',
  },
  {
    title: 'Resultado',
    text: 'Salida compacta para la UX final.',
    chips: ['risk', 'status', 'summary', 'reasons'],
    icon: iconResult,
    tone: 'result',
  },
];

const decisionRows = [
  { case: 'safe + complete', result: 'Seguro', action: 'Abrir', tone: 'safe' },
  { case: 'suspicious / partial / unavailable', result: 'Sospechoso', action: 'Confirmar', tone: 'warn' },
  { case: 'dangerous', result: 'Peligroso', action: 'Advertencia fuerte', tone: 'danger' },
];

const decisionStatuses = [
  { label: 'complete', text: 'Cobertura suficiente', tone: 'complete' },
  { label: 'partial', text: 'Cobertura parcial', tone: 'partial' },
  { label: 'unavailable', text: 'Sin base suficiente', tone: 'unavailable' },
];

const flowSteps = [
  { num: '1', title: 'Escanear', text: 'QR o URL', icon: iconCamera },
  { num: '2', title: 'Validar', text: 'Sintaxis OK', icon: iconShield },
  { num: '3', title: 'Enviar', text: 'Consulta segura', icon: iconSend },
  { num: '4', title: 'Analizar', text: 'Cruce de fuentes', icon: iconSearch },
  { num: '5', title: 'Mostrar', text: 'Semaforo final', icon: iconPhone },
  { num: '6', title: 'Decidir', text: 'Abrir o no', icon: iconLock },
  { num: '7', title: 'Guardar', text: 'Room local', icon: iconSave },
];

const costBars = [
  { label: 'Hardware', value: '1.700 EUR', height: '28%' },
  { label: 'Personal', value: '6.080 EUR', height: '100%' },
  { label: 'Gastos indirectos', value: '280 EUR', height: '8%' },
];

const closingCards = [
  { title: 'Producto', text: 'Un prototipo funcional que analiza URLs antes de abrirlas.' },
  { title: 'Valor', text: 'Reduce clics a ciegas y mejora la decision de usuarios no tecnicos.' },
  { title: 'Base tecnica', text: 'Arquitectura viable, decision conservadora y privacidad local.' },
];
---

<PresentacionLayout title="QR Scanner Security - Presentacion TFC">
  <div class="presentation-wrapper" id="presentacion">
    <div class="progress-bar-track" aria-hidden="true">
      <div class="progress-bar-fill" id="progressFill" style={`width:${100 / TOTAL_SLIDES}%`}></div>
    </div>

    <div class="slides-viewport" id="slidesViewport">
      <section class="slide active slide-cover" id="slide-1" data-slide="1" aria-label="Portada">
        <div class="slide-shell slide-shell--narrow cover-layout">
          <div class="slide-tag animate-fade-in">TFC · Defensa ante tribunal</div>
          <div class="cover-mark animate-scale delay-1" aria-hidden="true">
            <div class="cover-mark-shield" set:html={iconShield}></div>
            <div class="cover-mark-qr">
              <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="4" y="4" width="16" height="16" rx="2" fill="currentColor" />
                <rect x="28" y="4" width="16" height="16" rx="2" fill="currentColor" />
                <rect x="4" y="28" width="16" height="16" rx="2" fill="currentColor" />
                <rect x="8" y="8" width="8" height="8" rx="1" fill="white" />
                <rect x="32" y="8" width="8" height="8" rx="1" fill="white" />
                <rect x="8" y="32" width="8" height="8" rx="1" fill="white" />
                <rect x="28" y="28" width="4" height="4" rx="1" fill="currentColor" opacity=".75" />
                <rect x="34" y="28" width="4" height="4" rx="1" fill="currentColor" opacity=".75" />
                <rect x="28" y="34" width="4" height="4" rx="1" fill="currentColor" opacity=".75" />
                <rect x="40" y="40" width="4" height="4" rx="1" fill="currentColor" opacity=".55" />
              </svg>
            </div>
          </div>
          <h1 class="slide-title animate-fade-up delay-2">QR Scanner <span class="accent">Security</span></h1>
          <p class="slide-subtitle animate-fade-up delay-3">Analiza antes de abrir</p>
          <p class="cover-copy animate-fade-up delay-4">Aplicacion Android para revisar URLs de codigos QR antes de llevar al usuario al navegador.</p>
          <div class="cover-meta animate-fade-in delay-5">
            <span>Trabajo de fin de ciclo</span>
            <span>2025 - 2026</span>
            <span>Android + FastAPI</span>
          </div>
        </div>
      </section>

      <section class="slide" id="slide-2" data-slide="2" aria-label="Indice">
        <div class="slide-shell slide-shell--wide">
          <div class="slide-header">
            <div class="slide-tag animate-fade-in">Recorrido</div>
            <h2 class="slide-title animate-fade-up delay-1">Seis bloques para explicar el producto</h2>
            <p class="slide-subtitle animate-fade-up delay-2">Problema, usuario, solucion, arquitectura, demo y viabilidad.</p>
          </div>

          <div class="slide-stack slide-stack--between animate-fade-up delay-2">
            <div class="index-route" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
              <span></span>
              <span></span>
              <span></span>
            </div>

            <div class="index-grid">
              {indexBlocks.map((block) => (
                <button class="index-block" data-goto={block.goto} type="button">
                  <div class="index-number">{block.num}</div>
                  <div class="index-body">
                    <strong class="index-title">{block.title}</strong>
                    <span class="index-sub">{block.sub}</span>
                  </div>
                  <span class="index-meta">{block.slides}</span>
                </button>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="slide" id="slide-3" data-slide="3" aria-label="El Problema">
        <div class="slide-shell slide-shell--wide">
          <div class="slide-header">
            <div class="slide-tag slide-tag--danger animate-fade-in">El problema</div>
            <h2 class="slide-title animate-fade-up delay-1">El usuario escanea a ciegas</h2>
            <p class="slide-subtitle animate-fade-up delay-2">QR visible -> URL oculta -> decision sin contexto.</p>
          </div>

          <div class="slide-stack slide-stack--between slide-stack--problem animate-fade-up delay-3">
            <div class="problem-layout">
              <article class="story-card story-card--soft">
                <div class="story-kicker">Uso cotidiano</div>
                <h3 class="card-title">El QR parece legitimo por su contexto fisico</h3>
                <p class="body-text">Restaurantes, carteles, comercios y transporte convierten el escaneo en un gesto automatico.</p>
                <div class="chip-row">
                  <span class="chip">restauracion</span>
                  <span class="chip">movilidad</span>
                  <span class="chip">retail</span>
                  <span class="chip">eventos</span>
                </div>
              </article>

              <article class="story-card story-card--danger">
                <div class="story-kicker story-kicker--danger">Punto ciego</div>
                <h3 class="card-title">QR visible -> URL oculta -> decision sin contexto</h3>
                <p class="body-text">Ese salto basta para llevar a phishing, robo de credenciales o descarga maliciosa.</p>
                <div class="chain-note">Antes de abrir falta una lectura clara del riesgo.</div>
              </article>
            </div>

            <div class="problem-band animate-fade-up delay-4">
              <div class="problem-number">+25.000</div>
              <div class="problem-band-copy">
                <strong>casos de phishing gestionados por INCIBE en Espana en 2025</strong>
                <span>El dato acompana el contexto, pero la idea central sigue siendo la misma: el usuario decide sin ver la URL real.</span>
              </div>
            </div>

            <div class="closing-band animate-fade-up delay-5">Antes de abrir, hace falta una capa de analisis.</div>
          </div>
        </div>
      </section>

      <section class="slide" id="slide-4" data-slide="4" aria-label="Investigacion de Usuarios">
        <div class="slide-shell slide-shell--wide">
          <div class="slide-header">
            <div class="slide-tag animate-fade-in">Investigacion</div>
            <h2 class="slide-title animate-fade-up delay-1">La necesidad ya aparece en el uso real</h2>
            <p class="slide-subtitle animate-fade-up delay-2">Los QR ya son cotidianos, pero abrir sigue siendo una decision poco informada.</p>
          </div>

          <div class="slide-stack slide-stack--between animate-fade-up delay-3">
            <div class="metrics-grid">
              {researchStats.map((stat) => (
                <article class="metric-card">
                  <div class="metric-number">{stat.value}</div>
                  <div class="metric-label">{stat.label}</div>
                  <p class="metric-text">{stat.text}</p>
                </article>
              ))}
            </div>

            <div class="quote-band animate-fade-up delay-4">El usuario medio no necesita mas tecnicismo. Necesita una lectura clara antes del clic.</div>
          </div>
        </div>
      </section>

      <section class="slide" id="slide-5" data-slide="5" aria-label="Interes del Mercado">
        <div class="slide-shell slide-shell--wide">
          <div class="slide-header">
            <div class="slide-tag animate-fade-in">Mercado</div>
            <h2 class="slide-title animate-fade-up delay-1">La oportunidad depende de rapidez y claridad</h2>
            <p class="slide-subtitle animate-fade-up delay-2">Detectar riesgo no basta si el flujo no cabe en unos pocos segundos.</p>
          </div>

          <div class="slide-stack slide-stack--between animate-fade-up delay-3">
            <div class="metrics-grid metrics-grid--market">
              {marketStats.map((stat) => (
                <article class="metric-card metric-card--highlight">
                  <div class="metric-number">{stat.value}</div>
                  <div class="metric-label">{stat.label}</div>
                  <p class="metric-text">{stat.text}</p>
                </article>
              ))}
            </div>

            <div class="insight-panel animate-fade-up delay-4">
              <div class="insight-bar"></div>
              <div class="insight-copy">
                <p>La interfaz debe ser <strong>rapida, clara y sin tecnicismos</strong>.</p>
                <div class="insight-chips">
                  <span class="chip">respuesta en segundos</span>
                  <span class="chip">lectura inmediata</span>
                  <span class="chip">friccion minima</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="slide" id="slide-6" data-slide="6" aria-label="Persona Prototipo">
        <div class="slide-shell slide-shell--wide">
          <div class="slide-header">
            <div class="slide-tag animate-fade-in">Usuario</div>
            <h2 class="slide-title animate-fade-up delay-1">Persona prototipo: usuario cotidiano</h2>
            <p class="slide-subtitle animate-fade-up delay-2">Escanea con normalidad, confia en el contexto fisico y no sabe leer la URL oculta.</p>
          </div>

          <div class="slide-stack slide-stack--center animate-fade-up delay-3">
            <div class="persona-layout">
              <article class="persona-hero">
                <div class="persona-icon" set:html={iconUser}></div>
                <p>Escanea QR a diario, pero no sabe evaluar si el enlace es seguro.</p>
              </article>

              <div class="persona-grid">
                {personaCards.map((card) => (
                  <article class={`persona-card persona-card--${card.tone}`}>
                    <div class="mini-icon" set:html={card.icon}></div>
                    <h3 class="card-title">{card.title}</h3>
                    <p class="body-text">{card.text}</p>
                  </article>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="slide" id="slide-7" data-slide="7" aria-label="Propuesta de Valor">
        <div class="slide-shell slide-shell--wide">
          <div class="slide-header">
            <div class="slide-tag animate-fade-in">Solucion</div>
            <h2 class="slide-title animate-fade-up delay-1">De escanear a ciegas a decidir con contexto</h2>
            <p class="slide-subtitle animate-fade-up delay-2">La app se coloca entre el QR y el navegador para dar una lectura accionable del riesgo.</p>
          </div>

          <div class="slide-stack slide-stack--between animate-fade-up delay-3">
            <div class="value-flow">
            {valueSteps.map((step, index) => (
              <>
                <article class={`value-card value-card--${step.tone}`}>
                  <div class="value-number">{step.num}</div>
                  <h3 class="card-title">{step.title}</h3>
                  <p class="body-text">{step.text}</p>
                </article>
                {index < valueSteps.length - 1 && <div class="value-arrow" aria-hidden="true">→</div>}
              </>
            ))}
            </div>

            <div class="closing-band animate-fade-up delay-4">El usuario no necesita saber de ciberseguridad. Solo necesita una senal clara antes de abrir.</div>
          </div>
        </div>
      </section>

      <section class="slide" id="slide-8" data-slide="8" aria-label="MVP y Requisitos">
        <div class="slide-shell slide-shell--wide">
          <div class="slide-header">
            <div class="slide-tag animate-fade-in">MVP operativo</div>
            <h2 class="slide-title animate-fade-up delay-1">MVP operativo y requisitos clave</h2>
            <p class="slide-subtitle animate-fade-up delay-2">Flujo minimo completo, funciones reales y requisitos en formato compacto.</p>
          </div>

          <div class="slide-stack slide-stack--between slide-stack--tight animate-fade-up delay-3">
            <div class="mvp-layout">
              <div class="mvp-column">
                <div class="section-kicker">Funciones clave</div>
                <div class="feature-grid feature-grid--mvp">
                  {mvpFeatures.map((feature) => (
                    <article class="feature-card">
                      <div class="mini-icon" set:html={feature.icon}></div>
                      <h3 class="card-title">{feature.title}</h3>
                      <p class="body-text">{feature.text}</p>
                    </article>
                  ))}
                </div>
              </div>

              <div class="mvp-column mvp-column--requirements">
                <div class="section-kicker">Requisitos validados</div>
                <div class="requirements-grid">
                  {requirements.map((req) => (
                    <article class="requirement-chip">
                      <div class="req-id">{req.id}</div>
