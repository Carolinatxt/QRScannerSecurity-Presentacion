            <div style="background:#fff; padding:24px; border-radius:var(--radius-card); box-shadow:var(--shadow-card); border-top:4px solid var(--color-green);">
              <div style="display:flex; align-items:center; gap:8px; margin-bottom:12px;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" color="var(--color-green-dark)"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                <strong style="font-size:18px;">Es defendible</strong>
              </div>
              <p style="font-size:16px; color:var(--color-text-muted);">Arquitectura viable, enfoque conservador y privacidad local.</p>
            </div>
          </div>

          <div style="margin-top: 48px; display: flex; flex-direction: column; align-items: center; gap: 16px;">
            <p style="font-weight: 900; font-size: 42px; color:var(--color-green-dark); text-align:center; line-height:1.2;">Menos clics a ciegas.<br/>Más seguridad antes de abrir.</p>
            <p style="color: var(--color-text-muted); font-size:18px; margin-top:24px;">Muchas gracias. ¿Preguntas?</p>
          </div>
        </div>
      </section>

    </div><!-- /slides-viewport -->

    <!-- =====================================================
         CONTROLES DE NAVEGACIÓN (parte inferior)
         ===================================================== -->
    <nav class="slide-controls" aria-label="Controles de presentación">

      <!-- Hint de teclado (tooltip al hacer hover) -->
      <span class="keyboard-hint" aria-hidden="true">
        ← → para navegar &nbsp;·&nbsp; F para pantalla completa
      </span>

      <!-- Contador numérico -->
      <span class="slide-counter" id="slideCounter" aria-live="polite">1 / 14</span>

      <!-- Título de la slide actual -->
      <span class="slide-current-title" id="slideTitle" aria-hidden="true">Portada</span>

      <!-- Centro: prev → dots → next -->
      <div class="controls-center">
        <button class="btn-nav" id="btnPrev" aria-label="Diapositiva anterior" disabled>
          &#8592;
        </button>

        <!-- Dots de posición (se generan por JS) -->
        <div class="dots-track" id="dotsTrack" role="tablist" aria-label="Diapositivas"></div>

        <button class="btn-nav" id="btnNext" aria-label="Diapositiva siguiente">
          &#8594;
        </button>
      </div>

      <!-- Pantalla completa -->
      <button class="btn-fullscreen" id="btnFullscreen" aria-label="Activar pantalla completa">
        <!-- Icono expand (visible cuando NO está en fullscreen) -->
        <svg id="iconExpand" width="15" height="15" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>
        </svg>
        <!-- Icono compress (visible cuando ESTÁ en fullscreen) -->
        <svg id="iconCompress" width="15" height="15" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"
             style="display:none">
          <path d="M8 3v3a2 2 0 0 1-2 2H3m18 0h-3a2 2 0 0 1-2-2V3m0 18v-3a2 2 0 0 1 2-2h3M3 16h3a2 2 0 0 1 2 2v3"/>
        </svg>
        <span>Pantalla completa</span>
      </button>
    </nav>

  </div><!-- /presentation-wrapper -->

</PresentacionLayout>

