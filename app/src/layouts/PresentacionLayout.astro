---
/**
 * PresentacionLayout.astro
 * Layout dedicado para la presentación de TFC.
 * No afecta al Layout.astro original del proyecto.
 */
import '../styles/presentacion.css';

const { title = 'QR Scanner Security — Presentación TFC' } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="robots" content="noindex" />
    <title>{title}</title>
    <!-- Sistema de estilos de la presentación importado arriba -->
  </head>
  <body>
    <slot />
  </body>
</html>
